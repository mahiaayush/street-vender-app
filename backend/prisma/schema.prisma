datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  password  String
  name      String
  role      String   // "VENDOR" or "CUSTOMER"
  createdAt DateTime @default(now())
  
  // Relations
  shop      Shop?
  orders    Order[]  @relation("CustomerOrders")
}

model Shop {
  id          String           @id @default(uuid())
  name        String
  description String?          @db.Text
  category    String           // e.g., "Fruits", "Vegetables", "Fast Food", "Chaat"
  isActive    Boolean          @default(false)
  latitude    Float?
  longitude   Float?
  updatedAt   DateTime         @updatedAt
  
  // Regular operating hours
  operatingHours OperatingHours[]

  // Relations
  vendorId    String           @unique
  vendor      User             @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  orders      Order[]          @relation("ShopOrders")
  ratings     Rating[]
  menuItems   MenuItem[]
}

model OperatingHours {
  id        String @id @default(uuid())
  shopId    String
  shop      Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  day       String // "Monday", "Tuesday", etc.
  openTime  String // "HH:MM" e.g., "09:00"
  closeTime String // "HH:MM" e.g., "18:00"

  @@index([shopId])
}

model MenuItem {
  id             String               @id @default(uuid())
  shopId         String
  shop           Shop                 @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name           String
  description    String?              @db.Text
  price          Float
  daysAvailable  String               // Comma-separated days: "Monday,Tuesday,Wednesday"
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  unavailabilities MenuUnavailability[]

  @@index([shopId])
}

model MenuUnavailability {
  id         String   @id @default(uuid())
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  date       String   // "YYYY-MM-DD"
  createdAt  DateTime @default(now())

  @@unique([menuItemId, date])
  @@index([menuItemId])
}

model Order {
  id          String   @id @default(uuid())
  customerId  String
  customer    User     @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Cascade)
  shopId      String
  shop        Shop     @relation("ShopOrders", fields: [shopId], references: [id], onDelete: Cascade)
  items       String   @db.Text // JSON string of items e.g., '[{"name": "Apple", "qty": 2, "price": 100}]'
  totalAmount Float
  status      String   // "PENDING", "ACCEPTED", "DECLINED", "OUT_FOR_DELIVERY", "DELIVERED"
  deliveryLat Float
  deliveryLng Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId])
  @@index([shopId])
}

model Rating {
  id         String   @id @default(uuid())
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerId String
  stars      Int      // 1 to 5 stars
  comment    String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([shopId])
}

model NotificationSubscription {
  id        String   @id @default(uuid())
  shopId    String
  userId    String   // subscriber ID (customer or vendor)
  createdAt DateTime @default(now())

  @@index([shopId])
}
